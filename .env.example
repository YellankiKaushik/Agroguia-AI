# AGROGUIA.AI Environment Variables
# Copy this file to .env.local and fill in your real values.
# Never commit .env or .env.local to git.

# OpenRouter: required for AI advisory generation.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# MongoDB Atlas: required for auth, CRUD data, and advisory history.
# Use your Atlas connection string, including the database name.
# Example format:
# DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agroguia?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth / JWT: required for standalone login sessions.
# Generate a random secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here
APP_JWT_SECRET=your-random-jwt-secret-here
