# ─────────────────────────────────────────────────────────────
# AGROGUIA.AI — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env or .env.local to git.
# ─────────────────────────────────────────────────────────────

# ─── OpenAI (REQUIRED for AI advisory generation) ─────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ADVISORY_MODEL=gpt-4o-mini

# ─── MongoDB Database ─────────────────────────────────────────
# Get a free connection string from https://www.mongodb.com/atlas
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_PROVIDER=mongodb
DATABASE_NAME=agroguia

# ─── Auth / JWT ───────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here
APP_JWT_SECRET=your-random-jwt-secret-here
