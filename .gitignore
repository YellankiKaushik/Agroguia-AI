# ─── Dependencies ────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js ─────────────────────────────────────────────────
/.next/
/out/

# ─── Production build ────────────────────────────────────────
/build

# ─── Testing ─────────────────────────────────────────────────
/coverage

# ─── Environment & Secrets (NEVER push these) ────────────────
