.env.*
.env*.local
!.env.example

# ─── Env backup folder (contains real secrets) ───────────────
env_backup/

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug logs ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Certificates / PEM files ────────────────────────────────
*.pem

# ─── OS junk ─────────────────────────────────────────────────
